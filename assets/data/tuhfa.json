  "verses": [
    { "id": 1, "number": 1, "sectionId": 1, "sadr": "يَقُولُ رَاجِي رَحْمَةِ الْغَفُورِ", "ajuz": "دَوْمًا سُلَيْمَانُ هُوَ الجَمْزُورِي" },
    { "id": 2, "number": 2, "sectionId": 1, "sadr": "(الْحَمْدُ للَّهِ) مُصَلِّيًا عَلَى", "ajuz": "(مُحَمَّدٍ) وَآلهِ وَمَنْ تَلاَ" },
    { "id": 3, "number": 3, "sectionId": 1, "sadr": "وَبَعْدُ: هَذَا النَّظْمُ لِلْمُرِيدِ", "ajuz": "فِي النُّونِ والتَّنْوِينِ وَالْمُدُودِ" },
    { "id": 4, "number": 4, "sectionId": 1, "sadr": "سَمَّيْتُهُ (بِتُحْفَةِ الأَطْفَالِ)", "ajuz": "عَنْ شَيْخِنَا الْمِيهِىِّ ذِي الْكَمالِ" },
    { "id": 5, "number": 5, "sectionId": 1, "sadr": "أَرْجُو بِهِ أَنْ يَنْفَعَ الطُّلاَّبَا", "ajuz": "وَالأَجْرَ وَالْقَبُولَ وَالثَّوَابَا" },
    { "id": 6, "number": 6, "sectionId": 2, "sadr": "لِلنُّونِ إِنْ تَسْكُنْ وَلِلتَّنْوِينِ", "ajuz": "أَرْبَعُ أَحْكَامٍ فَخُذْ تَبْيِينِي" },
    { "id": 7, "number": 7, "sectionId": 2, "sadr": "فَالأَوَّلُ الإظْهَارُ قَبْلَ أَحْرُفِ", "ajuz": "لِلْحَلْقِ سِتٌّ رُتِّبَتْ فَلْتَعْرِفِ" },
    { "id": 8, "number": 8, "sectionId": 2, "sadr": "هَمْزٌ فَهَاءٌ ثُمَّ عَيْنٌ حَاءُ", "ajuz": "مُهْمَلَتَانِ ثُمَّ غَيْنٌ خَاءُ" },
    { "id": 9, "number": 9, "sectionId": 2, "sadr": "وَالثَّانِ إِدْغَامٌ بِسِتَّةٍ أَتَتْ", "ajuz": "فِي (يَرْمَلُونَ) عِنْدَهُمْ قَدْ ثَبَتَتْ" },
    { "id": 10, "number": 10, "sectionId": 2, "sadr": "لَكِنَّهَا قِسْمَانِ قِسْمٌ يُدْغَمَا", "ajuz": "فِيهِ بِغُنَّةٍ (بِيَنْمُو) عُلِمَا" },
    { "id": 11, "number": 11, "sectionId": 2, "sadr": "إِلاَّ إِذَا كَانَا بِكِلْمَةٍ فَلاَ", "ajuz": "تُدْغِمْ كَدُنْيَا ثُمَّ صِنْوَانٍ تَلاَ" },
    { "id": 12, "number": 12, "sectionId": 2, "sadr": "وَالثَّانِ إِدْغَامٌ بِغَيْرِ غُنَّهْ", "ajuz": "فِي اللاَّمِ وَالرَّا ثُمَّ كَرِّرَنَّهْ" },
    { "id": 13, "number": 13, "sectionId": 2, "sadr": "وَالثَّالثُ الإِقْلاَبُ عِنْدَ الْبَاءِ", "ajuz": "مِيمًا بِغُنَّةٍ مَعَ الإِخْفَاءِ" },
    { "id": 14, "number": 14, "sectionId": 2, "sadr": "وَالرَّابِعُ الإِخْفَاءُ عِنْدَ الْفَاضِلِ", "ajuz": "مِنَ الحُرُوفِ وَاجِبٌ لِلْفَاضِلِ" },
    { "id": 15, "number": 15, "sectionId": 2, "sadr": "فِي خَمْسَةٍ مِنْ بَعْدِ عَشْرٍ رَمْزُهَا", "ajuz": "فِي كِلْمِ هَذَا البَيْتِ قَد ضَّمَّنْتُهَا" },
    { "id": 16, "number": 16, "sectionId": 2, "sadr": "صِفْ ذَا ثَنَا كَمْ جَادَ شَخْصٌ قَدْ سَمَا", "ajuz": "دُمْ طَيِّبًا زِدْ فِي تُقًى ضَعْ ظَالِمَا" },
    { "id": 17, "number": 17, "sectionId": 3, "sadr": "وَغُنَّ مِيمًا ثُمَّ نُونًا شُدِّدَا", "ajuz": "وَسَمِّ كُلاً حَرْفَ غُنَّةٍ بَدَا" },
    { "id": 18, "number": 18, "sectionId": 4, "sadr": "وَالمِيمُ إِنْ تَسْكُنْ تَجِي قَبْلَ الْهِجَا", "ajuz": "لاَ أَلِفٍ لَيِّنَةٍ لِذِي الْحِجَا" },
    { "id": 19, "number": 19, "sectionId": 4, "sadr": "أَحْكَامُهَا ثَلاَثَةٌ لِمَنْ ضَبَطْ", "ajuz": "إِخْفَاءٌ ادْغَامٌ وَإِظْهَارٌ فَقَطْ" },
    { "id": 20, "number": 20, "sectionId": 4, "sadr": "فَالأَوَّلُ الإِخْفَاءُ عِنْدَ الْبَاءِ", "ajuz": "وَسَمِّهِ الشَّفْوِيَّ لِلْقُرَّاءِ" },
    { "id": 21, "number": 21, "sectionId": 4, "sadr": "وَالثَّانِ إِدْغَامٌ بِمِثْلِهَا أَتَى", "ajuz": "وَسَمِّ إدْغَامًا صَغِيرًا يَا فَتَى" },
    { "id": 22, "number": 22, "sectionId": 4, "sadr": "وَالثَّالِثُ الإِظْهَارُ فِي الْبَقِيَّهْ", "ajuz": "مِنْ أَحْرُفٍ وَسَمِّهَا شَفْوِيَّهْ" },
    { "id": 23, "number": 23, "sectionId": 4, "sadr": "وَاحْذَرْ لَدَى وَاوٍ وَفَا أَنْ تَخْتَفِي", "ajuz": "لِقُرْبِهَا وَلاتِّحَادِ فَاعْرِفِ" },
    { "id": 24, "number": 24, "sectionId": 5, "sadr": "لِلاَمِ أَلْ حَالاَنِ قَبْلَ الأَحْرُفِ", "ajuz": "أُولاَهُمَا إِظْهَارُهَا فَلْتَعْرِفِ" },
    { "id": 25, "number": 25, "sectionId": 5, "sadr": "قَبْلَ ارْبَعٍ مَعْ عَشْرَةٍ خُذْ عِلْمَهُ", "ajuz": "مِنِ (ابْغِ حَجَّكَ وَخَفْ عَقِيمَهُ)" },
    { "id": 26, "number": 26, "sectionId": 5, "sadr": "ثَانِيهِمَا إِدْغَامُهَا فِي أَرْبَعِ", "ajuz": "وَعَشْرَةٍ أَيْضًا وَرَمْزَهَا فَعِ" },
    { "id": 27, "number": 27, "sectionId": 5, "sadr": "طِبْ ثُمَّ صِلْ رُحْمًا تَفُزْ ضِفْ ذَا نِعَمْ", "ajuz": "دَعْ سُوءَ ظَنٍّ زُرْ شَرِيفًا لِلْكَرَمْ" },
    { "id": 28, "number": 28, "sectionId": 5, "sadr": "وَاللاَّمُ الاُولَى سَمِّهَا قَمَرِيَّهْ", "ajuz": "وَاللاَّمَ الاُخْرَى سَمِّهَا شَمْسِيَّهْ" },
    { "id": 29, "number": 29, "sectionId": 5, "sadr": "وأظْهِرَنَّ لاَمَ فِعْلٍ مُطْلَقَا", "ajuz": "فِي نَحْوِ قُلْ نَعَمْ وَقُلْنَا وَالْتَقَى" },
    { "id": 30, "number": 30, "sectionId": 6, "sadr": "إِنْ فِي الصِّفَاتِ وَالمَخَارِجِ اتَّفَقْ", "ajuz": "حَرْفَانِ فَالْمِثْلاَنِ فِيهِمَا أَحَقْ" },
    { "id": 31, "number": 31, "sectionId": 6, "sadr": "وَإِنْ يَكُونَا مَخْرَجًا تَقَارَبَا", "ajuz": "وَفِي الصِّفَاتِ اخْتَلَفَا يُلَقَّبَا" },
    { "id": 32, "number": 32, "sectionId": 6, "sadr": "مُتَقَارِبَيْنِ أَوْ يَكُونَا اتَّفَقَا", "ajuz": "فِي مَخْرَجٍ دُونَ الصِّفَاتِ حُقِّقَا" },
    { "id": 33, "number": 33, "sectionId": 6, "sadr": "بِالْمُتَجَانِسَيْنِ ثُمَّ إِنْ سَكَنْ", "ajuz": "أَوَّلُ كُلٍّ فَالصَّغِيرَ سَمِّيَنْ" },
    { "id": 34, "number": 34, "sectionId": 6, "sadr": "أَوْ حُرِّكَ الحَرْفَانِ فِي كُلٍّ فَقُلْ", "ajuz": "كُلٌّ كَبِيرٌ وافْهَمَنْهُ بِالْمُثُلْ" },
    { "id": 35, "number": 35, "sectionId": 7, "sadr": "وَالْمَدُّ أَصْلِيٌّ وَفَرْعِيٌّ لَهُ", "ajuz": "وَسَمِّ أَوَّلاً طَبِيعِيًّا وَهُو" },
    { "id": 36, "number": 36, "sectionId": 7, "sadr": "مَا لاَ تَوَقُّفٌ لَهُ عَلَى سَبَبْ", "ajuz": "وَلا بِدُونِهِ الحُرُوفُ تُجْتَلَبْ" },
    { "id": 37, "number": 37, "sectionId": 7, "sadr": "بلْ أَيُّ حَرْفٍ غَيْرُ هَمْزٍ أَوْ سُكُونْ", "ajuz": "جَا بَعْدَ مَدٍّ فَالطَّبِيعِيَّ يَكُونْ" },
    { "id": 38, "number": 38, "sectionId": 7, "sadr": "وَالآخَرُ الْفَرْعِيُّ مَوْقُوفٌ عَلَى", "ajuz": "سَبَبْ كَهَمْزٍ أَوْ سُكُونٍ مُسْجَلا" },
    { "id": 39, "number": 39, "sectionId": 7, "sadr": "حُرُوفُهُ ثَلاَثَةٌ فَعِيهَا", "ajuz": "مِنْ لَفْظِ (وَايٍ) وَهْيَ فِي نُوحِيهَا" },
    { "id": 40, "number": 40, "sectionId": 7, "sadr": "وَالكَسْرُ قَبْلَ الْيَا وَقَبْلَ الْواوِ ضَمْ", "ajuz": "شَرْطٌ وَفَتْحٌ قَبْلَ أَلْفٍ يُلْتَزَمْ" },
    { "id": 41, "number": 41, "sectionId": 7, "sadr": "وَاللِّينُ مِنْهَا الْيَا وَوَاوٌ سُكِّنَا", "ajuz": "إِنِ انْفِتَاحٌ قَبْلَ كُلٍّ أُعْلِنَا" },
    { "id": 42, "number": 42, "sectionId": 8, "sadr": "لِلْمَدِّ أَحْكَامٌ ثَلاَثَةٌ تَدُومْ", "ajuz": "وَهْيَ الْوُجُوبُ وَالْجَوَازُ وَاللُّزُومْ" },
    { "id": 43, "number": 43, "sectionId": 8, "sadr": "فَوَاجِبٌ إِنْ جَاءَ هَمْزٌ بَعْدَ مَدْ", "ajuz": "فِي كِلْمَةٍ وَذَا بِمُتَّصِلٍ يُعَدْ" },
    { "id": 44, "number": 44, "sectionId": 8, "sadr": "وَجَائِزٌ مَدٌّ وَقَصْرٌ إِنْ فُصِلْ", "ajuz": "كُلٌّ بِكِلْمَةٍ وَهَذَا المُنْفَصِلْ" },
    { "id": 45, "number": 45, "sectionId": 8, "sadr": "وَمِثْلُ ذَا إِنْ عَرَضَ السُّكُونُ", "ajuz": "وَقْفًا كَتَعْلَمُونَ نَسْتَعِينُ" },
    { "id": 46, "number": 46, "sectionId": 8, "sadr": "أَوْ قُدِّمَ الْهَمْزُ عَلَى المَدِّ وَذَا", "ajuz": "بَدَلْ كَآمَنُوا وَإِيمَانًا خُذَا" },
    { "id": 47, "number": 47, "sectionId": 8, "sadr": "وَلاَزِمٌ إِنِ السُّكُونُ أُصِّلاَ", "ajuz": "وَصْلاً وَوَقْفًا بَعْدَ مَدٍّ طُوِّلاَ" },
    { "id": 48, "number": 48, "sectionId": 9, "sadr": "أَقْسَامُ لاَزِمٍ لَدَيْهِمْ أَرْبَعَهْ", "ajuz": "وَتِلْكَ كِلْمِيٌّ وَحَرْفِيٌّ مَعَهْ" },
    { "id": 49, "number": 49, "sectionId": 9, "sadr": "كِلاَهُمَا مُخَفَّفٌ مُثَقَّلُ", "ajuz": "فَهَذِهِ أَرْبَعَةٌ تُفَصَّلُ" },
    { "id": 50, "number": 50, "sectionId": 9, "sadr": "فَإِنْ بِكِلْمَةٍ سُكُونٌ اجْتَمَعْ", "ajuz": "مَعْ حَرْفِ مَدٍّ فَهْوَ كِلْمِيٌّ وَقَعْ" },
    { "id": 51, "number": 51, "sectionId": 9, "sadr": "أَوْ فِي ثُلاَثِيِّ الحُرُوفِ وُجِدَا", "ajuz": "وَالمَدُّ وَسْطُهُ فَحَرْفِيٌّ بَدَا" },
    { "id": 52, "number": 52, "sectionId": 9, "sadr": "كِلاَهُمَا مُثَقَّلٌ إِنْ أُدْغِمَا", "ajuz": "مَخَفَّفٌ كُلٌّ إِذَا لَمْ يُدْغَمَا" },
    { "id": 53, "number": 53, "sectionId": 9, "sadr": "وَاللاَّزِمُ الْحَرْفِيُّ أَوَّلَ السُّوَرْ", "ajuz": "وُجُودُهُ وَفِي ثَمَانٍ انْحَصَرْ" },
    { "id": 54, "number": 54, "sectionId": 9, "sadr": "يَجْمَعُهَا حُرُوفُ (كَمْ عَسَلْ نَقَصْ)", "ajuz": "وَعَيْنُ ذُو وَجْهَيْنِ والطُّولُ أَخَصْ" },
    { "id": 55, "number": 55, "sectionId": 9, "sadr": "وَمَا سِوَى الحَرْفِ الثُّلاَثِي لاَ أَلِفْ", "ajuz": "فَمَدُّهُ مَدًّا طَبِيعِيًّا أُلِفْ" },
    { "id": 56, "number": 56, "sectionId": 9, "sadr": "وَذَاكَ أَيْضًا فِي فَوَاتِحِ السُّوَرْ", "ajuz": "فِي لَفْظِ (حَيٍّ طَاهِرٍ) قَدِ انْحَصَرْ" },
    { "id": 57, "number": 57, "sectionId": 9, "sadr": "وَيَجْمَعُ الْفَوَاتِحَ الأَرْبَعْ عَشَرْ", "ajuz": "(صِلْهُ سُحَيْرًا مَنْ قَطَعْكَ) ذَا اشْتَهَرْ" },
    { "id": 58, "number": 58, "sectionId": 10, "sadr": "وَتَمَّ ذَا النَّظْمُ بِحَمْدِ اللَّهِ", "ajuz": "عَلَى تَمَامِهِ بِلاَ تَنَاهِي" },
    { "id": 59, "number": 59, "sectionId": 10, "sadr": "أَبْيَاتُهُ نَدٌّ بَداَ لِذِي النُّهَى", "ajuz": "تَارِيخُهَا بُشْرَى لِمَنْ يُتْقِنُهَا" },
    { "id": 60, "number": 60, "sectionId": 10, "sadr": "ثُمَّ الصَّلاَةُ وَالسَّلاَمُ أَبَدَا", "ajuz": "عَلَى خِتَامِ الأَنْبِيَاءِ أَحْمَدَا" },
    { "id": 61, "number": 61, "sectionId": 10, "sadr": "وَالآلِ وَالصَّحْبِ وَكُلِّ تَابِعِ", "ajuz": "وَكُلِّ قَارِئٍ وكُلِّ سَامِعِ" }
  ],
  "sharhNotes": [
    {
      "id": 1, "noteNumber": "١", "verseIds": [6],
      "text": "النون الساكنة: هي التي لا حركة لها وتثبت خطا ولفظا ووصلا ووقفا وتكون في الأسماء والأفعال والحروف متوسطة ومتطرفة. والتنوين: نون ساكنة زائدة تلحق آخر الاسم لفظا ووصلا وتسقط خطا ووقفا ولا يكون إلا متطرفا. يعنى أن النون الساكنة والتنوين لهما بالنسبة لما يقع بعدهما من الحروف أربعة أحوال: الإظهار والإدغام والإقلاب والإخفاء."
    },
    {
      "id": 2, "noteNumber": "٢", "verseIds": [7, 8],
      "text": "يعنى أن الأول من أحوال النون الساكنة والتنوين الإظهار: وهو عبارة عن إخراج كل حرف من مخرجه من غير غنة في المظهر فيظهران إذا وقع بعدهما حرف من حروف الحلق الستة التي هي الهمزة والهاء والعين والحاء والغين والخاء ويسمى إظهارًا حلقيًا."
    },
    {
      "id": 3, "noteNumber": "٣", "verseIds": [9, 10, 11, 12],
      "text": "يعنى أن الثاني من أحوال النون الساكنة والتنوين الإدغام: وهو عبارة عن التلفظ بحرف ساكن فحرف متحرك بحيث يصيران كحرف واحد مشدد ويكون في ستة أحرف يجمعها قولك (يرملون) لكنها تنقسم إلى قسمين: أربعة منها يدغمان فيها بغنة وهى الياء والنون والميم والواو ويسمى إدغاما بغنة. وحرفان منها يدغمان فيهما بلا غنة وهما اللام والراء ويسمى إدغاما بلا غنة. لكن إذا اجتمعت النون مع الياء أو الواو في كلمة واحدة فلا تدغم."
    },
    {
      "id": 4, "noteNumber": "٤", "verseIds": [13],
      "text": "يعنى أن الثالث من أحوال النون الساكنة والتنوين الاقلاب: وهو عبارة عن قلبهما ميما عند الباء الموحدة مع الغنة نحو: أنبئهم، أن بورك، سميع بصير."
    },
    {
      "id": 5, "noteNumber": "٥", "verseIds": [14, 15, 16],
      "text": "يعنى أن الرابع من أحوال النون الساكنة والتنوين الإخفاء: وهو عبارة عن النطق بهما بحالة بين الإظهار والإدغام مع بقاء الغنة من غير تشديد وذلك يكون عند الخمسة عشر حرفا الباقية من حروف الهجاء: وهى الصاد والذال والثاء والكاف والجيم والشين والقاف والسين والدال والطاء والزاي والفاء والتاء والضاد والظاء. ويسمى إخفاء حقيقيا."
    },
    {
      "id": 6, "noteNumber": "٦", "verseIds": [17],
      "text": "المعنى أنه يجب إظهار غنة الميم والنون حال تشديدهما نحو: من الجنة وأن الناس ونحو: ثم ولما ومالهم من الله ويسمى كل منهما حرف غنة مشددا."
    },
    {
      "id": 7, "noteNumber": "٧", "verseIds": [18, 19, 20, 21, 22, 23],
      "text": "يعنى أن الميم الساكنة لها عند حروف الهجاء غير الألف اللينة ثلاثة أحوال: (الأول) الإخفاء عند الباء ويسمى إخفاء شفويا. (الثاني) الإدغام في مثلها ويسمى إدغاما صغيرًا. (الثالث) الإظهار عند باقي الحروف ويسمى إظهارًا شفويا. وتجب العناية بإظهارها عند الواو والفاء لقربها من الفاء ولاتحادها مع الواو في المخرج."
    },
    {
      "id": 8, "noteNumber": "٨", "verseIds": [24, 25, 26, 27, 28, 29],
      "text": "يعنى أن لام أل المعرفة لها عند حروف الهجاء حالتان: (الأولى) الإظهار وجوبا عند أربعة عشر حرفا يجمعها قولك (ابغ حجك وخف عقيمه) وتسمى اللام القمرية. (الثانية) الإدغام وجوبا في بقية الأحرف وتسمى اللام الشمسية. ولام الفعل يجب إظهارها مطلقًا."
    },
    {
      "id": 9, "noteNumber": "٩", "verseIds": [30, 31, 32, 33, 34],
      "text": "إن اتفق حرفان في الصفات وفي المخرج سميا مثلين. وإن تقارب الحرفان في المخرج واختلفا في الصفات سميا متقاربين. وإن اتفقا في المخرج واختلفا في الصفات سميا متجانسين. فإن سكن أولهما سمي صغيرا وإن تحركا سمي كبيرا."
    },
    {
      "id": 10, "noteNumber": "١٠", "verseIds": [35, 36, 37, 38],
      "text": "المد عبارة عن إطالة الصوت بحروفه وينقسم إلى أصلي وهو المد الطبيعي الذي لا تقوم ذات حرف المد إلا به ولا يتوقف على سبب من همز أو سكون ومقداره حركتان. وفرعي وهو الذي يتوقف على سبب من همز أو سكون."
    },
    {
      "id": 11, "noteNumber": "١١", "verseIds": [39, 40, 41],
